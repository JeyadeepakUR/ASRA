# ── Runtime ──
ENVIRONMENT=dev
LOG_LEVEL=INFO

# ── API Security (optional for local MVP) ──
API_KEY_ENABLED=false
API_KEY=
API_KEY_HEADER=x-api-key

# ── LLM Configuration ──
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL_NAME=gpt-4o

# ── Anomaly Detection ──
ANOMALY_CPU_THRESHOLD=85.0
ANOMALY_MEMORY_THRESHOLD=90.0
ANOMALY_ERROR_RATE_THRESHOLD=5.0

# ── RL Learning Engine ──
RL_LEARNING_RATE=0.001
RL_DISCOUNT_FACTOR=0.99
RL_REPLAY_BUFFER_SIZE=10000
RL_EPSILON=0.1

# ── Human in the Loop ──
APPROVAL_CONFIDENCE_THRESHOLD=0.75

# ── RAG / Embeddings (local Ollama setup) ──
RAG_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text
EMBEDDING_DIM=384
